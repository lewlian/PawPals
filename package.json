{
  "name": "pawpals-sg",
  "version": "1.0.0",
  "description": "Telegram bot for Singapore dog run real-time occupancy tracking",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "keywords": [
    "telegram",
    "bot",
    "singapore",
    "dog",
    "parks"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.2.3",
    "haversine-distance": "^1.2.4",
    "kysely": "^0.28.10",
    "pg": "^8.17.2",
    "pino": "^10.3.0",
    "redis": "^5.10.0",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/pg": "^8.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
