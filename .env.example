# PawPals SG Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# REQUIRED
# ===================

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# ===================
# DATABASE
# ===================

# Option 1: Connection URL (recommended for production)
# DATABASE_URL=postgresql://user:password@host:port/database

# Option 2: Individual credentials (for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pawpals
DB_USER=postgres
DB_PASSWORD=postgres

# ===================
# PRODUCTION ONLY
# ===================

# Set to 'production' for webhook mode
NODE_ENV=development

# Port for Express server (Railway injects this)
PORT=3000

# Your Railway/hosting domain (without https://)
# WEBHOOK_DOMAIN=your-app.up.railway.app

# Secret for webhook validation (generate with: openssl rand -hex 32)
# WEBHOOK_SECRET=

# Your Telegram user ID for admin notifications
# ADMIN_CHAT_ID=

# ===================
# OPTIONAL
# ===================

# Redis URL (reserved for future use)
REDIS_URL=redis://localhost:6379
